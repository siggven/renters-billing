# Copy this file to .env.local and fill in real values for app dev.
# Copy this file to .env.test.local and fill in real values for npm run smoke.
# BOTH .env.local and .env.test.local are gitignored.
#
# ── For .env.local ────────────────────────────────────────────────────────
# Get from Supabase dashboard:
#   Project → Settings → API → "Project URL" + "Publishable key"
# In CI (GitHub Actions), the same VITE_* values must also be set as repo
# secrets so the production build can embed them. Settings → Secrets and
# variables → Actions → New repository secret.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# ── For .env.test.local (only needed if you run `npm run smoke`) ──────────
# Create a DEDICATED test user in Supabase Auth (not your real account).
# Suggested email: smoke@bahaybills.local — fake but consistent.
# Generate a strong unique password (let your password manager handle it).
# Type both directly into .env.test.local — never paste them into chat.

SMOKE_TEST_EMAIL=smoke@bahaybills.local
SMOKE_TEST_PASSWORD=replace-with-strong-password-from-password-manager
