# Copy this file to .env.local and fill in real values.
# The .env.local file is gitignored.
#
# Get these from Supabase dashboard:
#   Project → Settings → API → "Project URL" + "Publishable key"
#
# In CI (GitHub Actions), the same two values must also be set as repo
# secrets so the production build can embed them. Settings → Secrets and
# variables → Actions → New repository secret.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx
